# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret key (sb_secret_...). Bypasses RLS — used by the scoring
# engine (Phase 3) and admin actions. NEVER prefix with NEXT_PUBLIC_ and never
# expose to the client.
SUPABASE_SECRET_KEY=

# Secret guarding the scheduled sync route (/api/cron/sync). Vercel sends it as
# the Authorization bearer when CRON_SECRET is set in the project env.
CRON_SECRET=

# Google Gemini API key for the Coach (server-only). Free tier.
GEMINI_API_KEY=

# Resend API key (server-only) — sends the lock-time reminder emails from
# /api/cron/reminders. Auth emails (magic links) go via Supabase's custom SMTP
# settings instead, not this key. Only needed in the Vercel project env.
RESEND_API_KEY=

# Public base URL used in outbound email links. Defaults to the production
# URL when unset, so local dev doesn't need it.
NEXT_PUBLIC_SITE_URL=
